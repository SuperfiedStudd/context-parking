{
  "manifest_version": 3,
  "name": "Context Parking — Chat Capture",
  "version": "1.1.0",
  "description": "Capture ChatGPT and Claude conversations into Context Parking.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
