{
  "manifest_version": 3,
  "name": "Context Parking — Chat Capture",
  "version": "1.0.0",
  "description": "Capture ChatGPT and Claude conversations into Context Parking.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
