{
  "manifest_version": 3,
  "name": "Context Parking — Chat Capture",
  "version": "1.2.1",
  "description": "Capture ChatGPT and Claude conversations into Context Parking.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:*/*",
    "https://*.lovable.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
